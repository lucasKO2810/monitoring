{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "expr": "ALERTS{alertname=~\"ServiceDown|ServiceSLABreach|ServiceUptimeBreach\", alertstate=\"firing\"}",
        "hide": false,
        "iconColor": "dark-red",
        "name": "SLA / Downtime Alerts",
        "titleFormat": "{{alertname}}",
        "textFormat": "{{service}}{{job}} — {{description}}"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "asDropdown": false, "icon": "arrow-left", "includeVars": false, "keepTime": true, "tags": [], "targetBlank": false, "title": "← Global Overview", "type": "link", "url": "/d/global-overview" },
    { "asDropdown": false, "icon": "dashboard", "includeVars": false, "keepTime": true, "tags": [], "targetBlank": false, "title": "Service Detail", "type": "link", "url": "/d/service-detail" },
    { "asDropdown": false, "icon": "dashboard", "includeVars": false, "keepTime": true, "tags": [], "targetBlank": false, "title": "Tracing", "type": "link", "url": "/d/distributed-tracing" },
    { "asDropdown": false, "icon": "dashboard", "includeVars": false, "keepTime": true, "tags": [], "targetBlank": false, "title": "Logs", "type": "link", "url": "/d/logs-explorer" },
    { "asDropdown": false, "icon": "dashboard", "includeVars": false, "keepTime": true, "tags": [], "targetBlank": false, "title": "Infrastructure", "type": "link", "url": "/d/infrastructure" },
    { "asDropdown": false, "icon": "dashboard", "includeVars": false, "keepTime": true, "tags": [], "targetBlank": false, "title": "Alerting", "type": "link", "url": "/d/alerting-overview" }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Average probe uptime across all application services over the last 24 hours.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.99 }, { "color": "green", "value": 0.999 }] },
          "unit": "percentunit",
          "decimals": 3
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg(avg by (service) (avg_over_time(up{job=\"sample-services\"}[24h])))", "legendFormat": "Overall Availability (24h)", "refId": "A", "instant": true }],
      "title": "Overall Availability (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of application services whose 24h uptime meets or exceeds the selected SLA target.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 3 }, { "color": "green", "value": 4 }] },
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(avg by (service) (avg_over_time(up{job=\"sample-services\"}[24h])) >= $sla_target) or vector(0)", "legendFormat": "Services Meeting SLA", "refId": "A", "instant": true }],
      "title": "Services Meeting SLA",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of services whose 24h uptime is below the selected SLA target.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 2 }] },
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(avg by (service) (avg_over_time(up{job=\"sample-services\"}[24h])) < $sla_target) or vector(0)", "legendFormat": "SLA Breaches", "refId": "A", "instant": true }],
      "title": "SLA Breaches",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Longest single-service downtime in the last 24 hours, in minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] },
          "unit": "m",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max((1 - avg by (service) (avg_over_time(up{job=\"sample-services\"}[24h]))) * 1440) or vector(0)", "legendFormat": "Max Downtime (24h)", "refId": "A", "instant": true }],
      "title": "Max Downtime (24h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 5,
      "title": "Service Uptime / Downtime Timeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Shows when each application service was reachable (UP) or unreachable (DOWN) based on Prometheus scrape probes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "mappings": [
            {
              "options": {
                "0": { "color": "dark-red", "index": 0, "text": "DOWN" },
                "1": { "color": "dark-green", "index": 1, "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "dark-red", "value": null }, { "color": "dark-green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 6,
      "options": { "alignValue": "center", "mergeValues": true, "rowHeight": 0.8, "showValue": "auto", "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"sample-services\"}", "legendFormat": "{{service}}", "refId": "A" }],
      "title": "Application Services — UP / DOWN",
      "type": "state-timeline"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Scrape reachability of each observability infrastructure component.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "mappings": [
            {
              "options": {
                "0": { "color": "dark-red", "index": 0, "text": "DOWN" },
                "1": { "color": "dark-green", "index": 1, "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "dark-red", "value": null }, { "color": "dark-green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "id": 7,
      "options": { "alignValue": "center", "mergeValues": true, "rowHeight": 0.8, "showValue": "auto", "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=~\"prometheus|loki|tempo|otel-collector|node-exporter\"}", "legendFormat": "{{job}}", "refId": "A" }],
      "title": "Infrastructure — UP / DOWN",
      "type": "state-timeline"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 8,
      "title": "SLA Verification",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Multi-window availability per service. Uptime is probe-based (scrape reachability). HTTP columns show request success rate (non-5xx). Values below SLA target appear red.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.99 }, { "color": "green", "value": 0.999 }] },
          "unit": "percentunit",
          "decimals": 3,
          "custom": { "align": "center", "cellOptions": { "mode": "gradient", "type": "color-background" }, "inspect": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Service" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "custom.width", "value": 120 },
              { "id": "custom.align", "value": "left" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "mappings", "value": [{ "options": { "0": { "color": "dark-red", "index": 0, "text": "DOWN" }, "1": { "color": "dark-green", "index": 1, "text": "UP" } }, "type": "value" }] },
              { "id": "unit", "value": "none" },
              { "id": "custom.width", "value": 80 }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 15, "x": 0, "y": 21 },
      "id": 9,
      "options": { "showHeader": true, "sortBy": [{ "desc": false, "displayName": "Service" }], "cellHeight": "md", "footer": { "countRows": false, "enablePagination": false, "show": false } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "min by (service) (up{job=\"sample-services\"})", "format": "table", "instant": true, "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg by (service) (avg_over_time(up{job=\"sample-services\"}[1h]))", "format": "table", "instant": true, "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg by (service) (avg_over_time(up{job=\"sample-services\"}[24h]))", "format": "table", "instant": true, "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg by (service) (avg_over_time(up{job=\"sample-services\"}[7d]))", "format": "table", "instant": true, "refId": "D" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - (sum by (service) (rate(http_requests_total{job=\"sample-services\", status_code=~\"5..\"}[24h])) / clamp_min(sum by (service) (rate(http_requests_total{job=\"sample-services\"}[24h])), 0.001))", "format": "table", "instant": true, "refId": "E" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - (sum by (service) (rate(http_requests_total{job=\"sample-services\", status_code=~\"5..\"}[7d])) / clamp_min(sum by (service) (rate(http_requests_total{job=\"sample-services\"}[7d])), 0.001))", "format": "table", "instant": true, "refId": "F" }
      ],
      "title": "Per-Service SLA Verification",
      "type": "table",
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "instance": true, "__name__": true },
            "indexByName": { "service": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3, "Value #D": 4, "Value #E": 5, "Value #F": 6 },
            "renameByName": { "service": "Service", "Value #A": "Status", "Value #B": "1h Uptime", "Value #C": "24h Uptime", "Value #D": "7d Uptime", "Value #E": "24h HTTP", "Value #F": "7d HTTP" }
          }
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Downtime per service in the last 24 hours, measured in minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] },
          "unit": "m",
          "decimals": 1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 9, "x": 15, "y": 21 },
      "id": 10,
      "options": { "displayMode": "gradient", "minVizHeight": 10, "minVizWidth": 0, "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true, "valueMode": "color", "sizing": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sort_desc((1 - avg by (service) (avg_over_time(up{job=\"sample-services\"}[24h]))) * 1440)", "legendFormat": "{{service}}", "refId": "A", "instant": true }],
      "title": "Downtime per Service (24h)",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 11,
      "title": "Availability Trends",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rolling 1-hour probe uptime per service. The dashed red line shows the selected SLA target.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "thresholdsStyle": { "mode": "off" } },
          "unit": "percentunit",
          "decimals": 3,
          "min": 0.95,
          "max": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLA Target" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 32 },
      "id": 12,
      "options": { "legend": { "calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg by (service) (avg_over_time(up{job=\"sample-services\"}[1h]))", "legendFormat": "{{service}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "vector($sla_target)", "legendFormat": "SLA Target", "refId": "B" }
      ],
      "title": "Service Uptime (1h rolling)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rolling 1-hour HTTP success rate per service. Shows the percentage of requests that did NOT return 5xx.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "thresholdsStyle": { "mode": "off" } },
          "unit": "percentunit",
          "decimals": 3,
          "min": 0.95,
          "max": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLA Target" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 32 },
      "id": 13,
      "options": { "legend": { "calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - (\n  sum by (service) (rate(http_requests_total{job=\"sample-services\", status_code=~\"5..\"}[1h]))\n  /\n  clamp_min(sum by (service) (rate(http_requests_total{job=\"sample-services\"}[1h])), 0.001)\n)", "legendFormat": "{{service}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "vector($sla_target)", "legendFormat": "SLA Target", "refId": "B" }
      ],
      "title": "HTTP Availability (1h rolling)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 14,
      "title": "Checkout SLO Detail",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Percentage of /checkout requests completing successfully over a 30-day rolling window.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.999 }, { "color": "green", "value": 0.9995 }] },
          "unit": "percentunit",
          "decimals": 3
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 42 },
      "id": 15,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - (\n  sum(increase(http_requests_total{job=\"sample-services\", service=\"frontend\", route=\"/checkout\", status_code=~\"5..\"}[30d]))\n  /\n  clamp_min(sum(increase(http_requests_total{job=\"sample-services\", service=\"frontend\", route=\"/checkout\"}[30d])), 1)\n)", "legendFormat": "Checkout Availability", "refId": "A", "instant": true }],
      "title": "Checkout Availability (30d)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "How much error budget remains. 100% = no errors consumed. 0% = SLO breached.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.25 }, { "color": "green", "value": 0.5 }] },
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 42 },
      "id": 16,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "clamp_min(\n  1 - (\n    (\n      sum(increase(http_requests_total{job=\"sample-services\", service=\"frontend\", route=\"/checkout\", status_code=~\"5..\"}[30d]))\n      /\n      clamp_min(sum(increase(http_requests_total{job=\"sample-services\", service=\"frontend\", route=\"/checkout\"}[30d])), 1)\n    )\n    / 0.001\n  )\n, 0)", "legendFormat": "Error Budget Remaining", "refId": "A", "instant": true }],
      "title": "Error Budget Remaining",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "percentunit",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 42 },
      "id": 17,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "vector(0.999)", "legendFormat": "SLO Target", "refId": "A", "instant": true }],
      "title": "SLO Target",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rate at which error budget is being consumed. >1 means budget is being consumed faster than the 30d window allows.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }] },
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 42 },
      "id": 18,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "slo:checkout_burn_rate:1h", "legendFormat": "1h Burn Rate", "refId": "A" }],
      "title": "1h Burn Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "6-hour error budget consumption rate.",
      "fieldConfig": {
